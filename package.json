{
  "name": "playwright-eventswidget-test",
  "version": "1.0.0",
  "private": true,
  "description": "Автотест Playwright для конструктора календаря событий 3SNET (dev.3snet.info/eventswidget).",
  "scripts": {
    "test": "npx playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:show": "npm-run-all --continue-on-error -s test allure:generate allure:serve"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "allure-commandline": "^2.38.0",
    "allure-playwright": "^3.6.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.0.0"
  }
}
